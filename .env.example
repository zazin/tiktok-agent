# Copy to .env and fill in. Real environment variables always win over .env.
# Every CLI auto-loads .env at startup via env_loader.load_env().

# --- HiveMQ source (default) — MQTT over TLS, username/password auth ---
HIVEMQ_HOST=xxxx.s1.eu.hivemq.cloud   # cluster host (required)
HIVEMQ_USERNAME=                      # required
HIVEMQ_PASSWORD=                      # required
HIVEMQ_PORT=8883                      # optional, defaults to 8883 (TLS)
HIVEMQ_TOPIC=tiktok/posts             # optional, work topic to drain
HIVEMQ_STATUS_TOPIC=tiktok/status     # optional, where outcomes are published
HIVEMQ_CLIENT_ID=tiktok-agent         # optional, stable id -> persistent session

# --- Comment-on-post (tiktok-commenter) — reuses the HiveMQ creds above ---
HIVEMQ_COMMENT_TOPIC=tiktok/comments               # optional, comment work topic to drain
HIVEMQ_COMMENT_STATUS_TOPIC=tiktok/comment-status  # optional, where comment outcomes are published
HIVEMQ_COMMENT_CLIENT_ID=tiktok-commenter          # optional, stable id -> its own persistent session

# --- Comment-reader (tiktok-comment-reader) — read a post's comments for the backend ---
HIVEMQ_COMMENT_READ_TOPIC=tiktok/comments-read       # optional, read-job topic to drain
HIVEMQ_COMMENT_LIST_TOPIC=tiktok/comments-list       # optional, where scraped comment lists are published
HIVEMQ_COMMENT_READ_CLIENT_ID=tiktok-comment-reader  # optional, stable id -> its own persistent session
COMMENT_READ_MAX=10                                  # optional, default cap on comments scraped per post

# --- Local testing isolation (all consumers) ---
# Prepended verbatim to every topic AND client-id so a test run uses a fully
# isolated queue + session. Leave UNSET in prod.
# HIVEMQ_TOPIC_PREFIX=test/            # optional, e.g. "test/" -> test/tiktok/posts

# --- Device serialization (all consumers share the one phone) ---
# Dir holding the cross-process device lock file (core/device_lock.py). Defaults
# to the system temp dir; only set this if temp isn't shared across the processes.
# TIKTOK_DEVICE_LOCK_DIR=/tmp          # optional

# --- ImageKit — still needed to download images (and for --source imagekit) ---
IMAGEKIT_PRIVATE_KEY=private_...                   # required to list/download
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
